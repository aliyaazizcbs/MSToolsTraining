## .gitignore for .NET 10 + Visual Studio + Aspire + Vite/Node frontend
## Covers: Visual Studio, VS Code, .NET build output, NuGet, Aspire, and Node/Vite

# ── Visual Studio ─────────────────────────────────────────────────────────────
.vs/
*.user
*.userosscache
*.suo
*.rsuser
*.vsp
*.vspx
*.psess
.idea/

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ── .NET Build output ─────────────────────────────────────────────────────────
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Publish output
**/publish/
**/PublishProfiles/

# ── NuGet ─────────────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
.nuget/
packages/
!**/[Pp]ackages/build/

# ── MSBuild ───────────────────────────────────────────────────────────────────
*.binlog

# ── Test results ──────────────────────────────────────────────────────────────
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
CodeCoverage/

# ── .NET Aspire ───────────────────────────────────────────────────────────────
.aspire/
**/aspire-manifest.json

# ── Node / Vite / npm (frontend) ──────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pfx
*.p12
secrets.json
appsettings.Development.json

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
~$*
*~
